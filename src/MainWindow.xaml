<Window x:Class="WireGuardTunnel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WireGuard Tunnel" Height="750" Width="450" 
        Background="#0F0F1B" Foreground="#FFFFFF" 
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing" ResizeMode="CanMinimize"
        WindowStyle="None" AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#2A2A3A"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="12" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A3A4A"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1A1A2A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A2A"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#2A2A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#1A1A2A"/>
            <Setter Property="BorderBrush" Value="#2A2A3A"/>
            <Setter Property="Foreground" Value="#4A4A5A"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Grid>
                            <Border Name="MainBorder" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                                <ScrollViewer Focusable="false" 
                                         HorizontalScrollBarVisibility="Disabled"
                                         VerticalScrollBarVisibility="Auto"
                                         Margin="0">
                                    <ItemsPresenter SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}" 
                                              Margin="{TemplateBinding Padding}"/>
                                </ScrollViewer>
                            </Border>
                            <Border Name="DisabledOverlay"
                                Background="#0A1A2F"
                                CornerRadius="12"
                                Visibility="Collapsed">
                                <Border.OpacityMask>
                                    <VisualBrush Visual="{Binding ElementName=MainBorder}"/>
                                </Border.OpacityMask>
                                <Viewbox Width="40" Height="40" Opacity="0.8">
                                    <TextBlock Text="🔒" FontSize="32" 
                                           Foreground="#4A6FA5" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                                </Viewbox>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="DisabledOverlay" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="MainBorder" Property="Opacity" Value="0.5"/>
                                <Setter TargetName="MainBorder" Property="Background" Value="#1A2A3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#0F0F1B" BorderBrush="#2A2A3A" BorderThickness="1">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок окна -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="12" Background="#2A2A3A">
                    <TextBlock Text="🔒" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="WireGuard Tunnel" FontSize="18" FontWeight="Bold" Foreground="#FFFFFF"/>
                    <TextBlock Text="Split Tunneling Client" FontSize="11" Foreground="#6A6A7A"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="MinimizeBtn" Content="─" Width="30" Height="30" 
                            Style="{StaticResource ModernButton}" Background="Transparent"
                            Click="MinimizeBtn_Click" Margin="0,0,5,0"/>
                    <Button x:Name="CloseBtn" Content="✕" Width="30" Height="30" 
                            Style="{StaticResource ModernButton}" Background="Transparent"
                            Click="CloseBtn_Click"/>
                </StackPanel>
            </Grid>

            <!-- Индикатор статуса -->
            <Border Grid.Row="1" CornerRadius="12" Background="#1A1A2A" Padding="15" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#2A2A3A"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                                        <Setter Property="Background" Value="#00C48C"/>
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation 
                                                        Storyboard.TargetProperty="Opacity"
                                                        From="0.5" To="1" Duration="0:0:1"
                                                        AutoReverse="True"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock x:Name="StatusIcon" Text="🔴" FontSize="20" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="StatusText" Text="Disconnected" 
                                   FontSize="14" FontWeight="SemiBold" Foreground="#FF6B6B"/>
                        <TextBlock x:Name="StatusDetail" Text="Ready to connect" 
                                   FontSize="11" Foreground="#6A6A7A"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Поле для ввода конфига -->
            <Border Grid.Row="2" CornerRadius="12" Background="#1A1A2A" Padding="10" Margin="0,0,0,15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="WIREGUARD CONFIG" 
                               Foreground="#6A6A7A" FontSize="10" FontWeight="Bold"
                               Margin="0,0,0,5"/>

                    <TextBox x:Name="ConfigTextBox" Grid.Row="1" 
                             Height="100" 
                             Background="#0A0A14"
                             BorderBrush="#2A2A3A"
                             Foreground="#FFFFFF"
                             FontFamily="Consolas"
                             FontSize="11"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Padding="8"/>

                    <Button x:Name="SaveConfigBtn" Grid.Row="2" 
                            Content="💾 Сохранить конфиг" 
                            Style="{StaticResource ModernButton}"
                            Background="#4A6FA5"
                            FontSize="11"
                            Padding="8,5"
                            Margin="0,5,0,0"
                            Click="SaveConfig_Click"/>
                </Grid>
            </Border>

            <!-- Приложения -->
            <Grid Grid.Row="3" Margin="0,0,0,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="APPLICATIONS" 
                               Foreground="#6A6A7A" FontSize="10" FontWeight="Bold"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="🔄 Refresh" 
                                Style="{StaticResource ModernButton}" 
                                Background="#1A1A2A" FontSize="11"
                                Padding="10,5" Margin="0,0,5,0"
                                Click="RefreshProcessList_Click"/>
                        <Button Content="✓ Select All" 
                                Style="{StaticResource ModernButton}" 
                                Background="#1A1A2A" FontSize="11"
                                Padding="10,5" Click="SelectAll_Click"/>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" CornerRadius="12" Background="#1A1A2A" 
                        BorderBrush="#2A2A3A" BorderThickness="1">
                    <ListBox x:Name="AppListBox" Background="Transparent" 
                             BorderThickness="0" Padding="10" 
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8" Background="#2A2A3A" 
                                        Margin="0,2" Padding="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" 
                                                  IsChecked="{Binding IsSelected}" 
                                                  Margin="0,0,8,0"
                                                  VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding DisplayName}" 
                                                       Foreground="#FFFFFF" 
                                                       FontSize="12"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Name}" 
                                                       Foreground="#6A6A7A" 
                                                       FontSize="9"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>

            <!-- Кнопка действия и статус конфига -->
            <StackPanel Grid.Row="4">
                <TextBlock x:Name="ConfigStatusText" Text="" 
                           Foreground="#4A6FA5" FontSize="10" 
                           HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <Button x:Name="BtnAction" 
                        Content="START TUNNEL" Height="50" 
                        Style="{StaticResource ModernButton}"
                        Background="#00C48C" Foreground="#FFFFFF"
                        Click="BtnAction_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>